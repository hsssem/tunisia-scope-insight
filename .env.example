# Public client variables used by Vite.
VITE_SUPABASE_PROJECT_ID=your-project-ref
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Server variables used by TanStack server functions.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
BACKOFFICE_PASSCODE=change-this-passcode
NVIDIA_API_KEY=your-nvidia-api-key

# Supabase migration script variables.
# Use either SUPABASE_DB_URL or SUPABASE_PROJECT_REF + PGPASSWORD.
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-your-region.pooler.supabase.com:6543/postgres
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_POOLER_REGION=eu-central-1
SUPABASE_DB_USER=postgres.your-project-ref
SUPABASE_DB_PORT=6543
PGPASSWORD=your-db-password
